rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isValidString(str, minLen, maxLen) {
      return str is string && str.size() >= minLen && str.size() <= maxLen;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ─── Users ───────────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone authenticated can read user profiles
      allow read: if isAuthenticated();

      // Only the owner can write, with validation
      allow create: if isOwner(userId)
        && hasRequiredFields(['uid', 'email', 'displayName', 'username'])
        && isValidString(request.resource.data.displayName, 1, 50)
        && isValidString(request.resource.data.email, 5, 100);

      allow update: if isOwner(userId)
        // Prevent privilege escalation
        && !('role' in request.resource.data.diff(resource.data).affectedKeys())
        && !('verified' in request.resource.data.diff(resource.data).affectedKeys())
        && !('uid' in request.resource.data.diff(resource.data).affectedKeys())
        && isValidString(request.resource.data.displayName, 1, 50);

      allow delete: if false; // Soft-delete only
    }

    // ─── Usernames ───────────────────────────────────────────────────────
    match /usernames/{username} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false; // Once set, usernames can't be changed
    }

    // ─── Posts ───────────────────────────────────────────────────────────
    match /posts/{postId} {
      // Public posts readable by all authenticated users
      allow read: if isAuthenticated() &&
        (resource.data.isPublic == true || resource.data.authorId == request.auth.uid);

      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid
        && isValidString(request.resource.data.content, 1, 2000)
        && hasRequiredFields(['authorId', 'content', 'isPublic', 'createdAt']);

      allow update: if isAuthenticated()
        && (
          // Owner can edit their post
          resource.data.authorId == request.auth.uid
          // Or only counter fields can be updated (likes, comments, shares)
          || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likesCount', 'commentsCount', 'sharesCount', 'viewsCount', 'updatedAt'])
        );

      allow delete: if isAuthenticated()
        && resource.data.authorId == request.auth.uid;
    }

    // ─── Comments ────────────────────────────────────────────────────────
    match /comments/{commentId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid
        && isValidString(request.resource.data.content, 1, 500)
        && hasRequiredFields(['postId', 'authorId', 'content', 'createdAt']);

      allow update: if isAuthenticated()
        && (
          resource.data.authorId == request.auth.uid
          || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likesCount', 'repliesCount', 'updatedAt'])
        );

      allow delete: if isAuthenticated()
        && resource.data.authorId == request.auth.uid;
    }

    // ─── Reactions ───────────────────────────────────────────────────────
    match /reactions/{reactionId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        // reactionId must be userId_targetId
        && reactionId == request.auth.uid + '_' + request.resource.data.targetId
        && hasRequiredFields(['userId', 'targetId', 'targetType', 'type']);

      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      allow update: if false;
    }

    // ─── Follows ─────────────────────────────────────────────────────────
    match /follows/{followId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && request.resource.data.followerId == request.auth.uid
        && followId == request.auth.uid + '_' + request.resource.data.followingId
        // Can't follow yourself
        && request.resource.data.followingId != request.auth.uid
        && hasRequiredFields(['followerId', 'followingId', 'createdAt']);

      allow delete: if isAuthenticated()
        && resource.data.followerId == request.auth.uid;

      allow update: if false;
    }

    // ─── Conversations ───────────────────────────────────────────────────
    match /conversations/{convId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participantIds;

      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participantIds
        && hasRequiredFields(['type', 'participantIds', 'lastMessageAt']);

      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participantIds
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['lastMessage', 'lastMessageAt', 'updatedAt']);

      allow delete: if false;
    }

    // ─── Messages ────────────────────────────────────────────────────────
    match /messages/{messageId} {
      allow read: if isAuthenticated()
        && get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participantIds.hasAny([request.auth.uid]);

      allow create: if isAuthenticated()
        && request.resource.data.senderId == request.auth.uid
        && isValidString(request.resource.data.content, 1, 2000)
        && hasRequiredFields(['conversationId', 'senderId', 'content', 'type', 'createdAt']);

      allow update: if isAuthenticated()
        // Only readBy can be updated by participants
        && get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participantIds.hasAny([request.auth.uid])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy', 'reactions', 'updatedAt']);

      allow delete: if isAuthenticated()
        && resource.data.senderId == request.auth.uid;
    }

    // ─── Notifications ───────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated()
        && resource.data.recipientId == request.auth.uid;

      allow create: if isAuthenticated()
        && request.resource.data.senderId == request.auth.uid
        && hasRequiredFields(['recipientId', 'senderId', 'type', 'isRead', 'createdAt']);

      allow update: if isAuthenticated()
        && resource.data.recipientId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'updatedAt']);

      allow delete: if isAuthenticated()
        && resource.data.recipientId == request.auth.uid;
    }

    // ─── Voice Calls ─────────────────────────────────────────────────────
    match /calls/{callId} {
      allow read: if isAuthenticated()
        && (resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid);

      allow create: if isAuthenticated()
        && request.resource.data.callerId == request.auth.uid
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.calleeId in request.resource.data.participantIds
        && hasRequiredFields(['conversationId', 'callerId', 'calleeId', 'participantIds', 'status', 'offer', 'createdAt']);

      allow update: if isAuthenticated()
        && (resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid);

      allow delete: if false;
    }

    // ─── Spaces ──────────────────────────────────────────────────────────
    match /spaces/{spaceId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && isValidString(request.resource.data.name, 3, 50)
        && hasRequiredFields(['name', 'slug', 'ownerId', 'isPrivate']);

      allow update: if isAuthenticated()
        && (
          resource.data.ownerId == request.auth.uid
          || request.auth.uid in resource.data.moderatorIds
          || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['membersCount', 'updatedAt'])
        );

      allow delete: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid;
    }

    match /spaces/{spaceId}/members/{memberId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && request.auth.uid == memberId
        && request.resource.data.userId == request.auth.uid
        && hasRequiredFields(['userId', 'role', 'joinedAt']);

      allow update: if false;

      allow delete: if isAuthenticated()
        && request.auth.uid == memberId;
    }

    // ─── Saved Posts ─────────────────────────────────────────────────────
    match /savedPosts/{savedId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && savedId == request.auth.uid + '_' + request.resource.data.postId;

      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      allow update: if false;
    }
  }
}
